{
  "name": "multi-ai-chat-desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:injected": "esbuild injected/bootstrap.ts injected/engine.ts --bundle --format=iife --platform=browser --target=es2020 --outdir=src-tauri/gen/injected",
    "agent:doctor": "node scripts/agent/doctor.mjs",
    "agent:audit": "node scripts/agent/audit.mjs",
    "agent:launch": "node scripts/agent/launch.mjs",
    "agent:status": "node scripts/agent/status.mjs",
    "agent:stop": "node scripts/agent/stop.mjs",
    "agent:verify": "node --test scripts/agent/tests/*.test.mjs",
    "pack:portable": "node scripts/pack-portable.mjs",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "pnpm build:injected && pnpm typecheck && pnpm lint && pnpm test && pnpm agent:verify && node scripts/check-adapters.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
