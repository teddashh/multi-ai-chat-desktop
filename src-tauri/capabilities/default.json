{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Control pane permissions only. Provider webview labels receive zero Tauri permissions per SPEC 6.1.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "allow-provider-open",
    "allow-provider-close",
    "allow-provider-show",
    "allow-provider-hide",
    "allow-provider-set-bounds",
    "allow-provider-eval",
    "allow-provider-eval-with-callback",
    "allow-provider-open-login",
    "allow-provider-open-login-external",
    "allow-provider-reload",
    "allow-connections-get",
    "allow-dev-log",
    "allow-adapter-push",
    "allow-report-broken",
    "allow-open-adapter-issue",
    "allow-settings-get",
    "allow-settings-set",
    "allow-publish-hackmd",
    "allow-export-markdown"
  ]
}
